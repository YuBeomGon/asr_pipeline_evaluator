# --- Raw data (never commit audio, labels, or generated manifest) -----------
# Keep only directory placeholders so the folder shape is preserved.
data/audio/*
data/labels/*
data/manifest.jsonl
!data/audio/.gitkeep
!data/labels/.gitkeep

# --- Bakeoff outputs / reports ---------------------------------------------
# Candidate outputs and evaluator reports are produced per-run; do not track.
outputs/*/*
!outputs/*/.gitkeep
reports/*
!reports/.gitkeep

# --- Framework workspaces ---------------------------------------------------
# Spec Kit / OpenSpec / GSD / BMAD install into their own workspace and may
# create lockfiles, caches, and tool-specific state. Keep only placeholders.
workspaces/*/*
!workspaces/*/.gitkeep

# --- Python -----------------------------------------------------------------
__pycache__/
*.pyc
*.pyo
.venv/
venv/

# --- Local Claude Code state ------------------------------------------------
.claude/settings.local.json

# --- Editor / OS noise ------------------------------------------------------
.DS_Store
*.swp
*.swo
