# --- Raw data (never commit audio, labels, or generated manifest) -----------
# Keep only directory placeholders so the folder shape is preserved.
data/audio/*
data/labels/*
data/manifest.jsonl
!data/audio/.gitkeep
!data/labels/.gitkeep

# --- Bakeoff outputs / reports ---------------------------------------------
# outputs/ is excluded (re-generatable); reports/ and workspaces/ are tracked.
outputs/*/*
!outputs/*/.gitkeep

# --- Python -----------------------------------------------------------------
__pycache__/
*.pyc
*.pyo
.venv/
venv/

# --- Local Claude Code state ------------------------------------------------
.claude/settings.local.json

# --- Editor / OS noise ------------------------------------------------------
.DS_Store
*.swp
*.swo
